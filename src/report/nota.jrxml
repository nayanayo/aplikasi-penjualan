<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="null" language="groovy" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="d20364e5-cd26-4607-95ba-50b05d04558e">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="id_nota" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT
     pelanggan.`id` AS pelanggan_id,
     pelanggan.`nmplg` AS pelanggan_nmplg,
     pelanggan.`jenis` AS pelanggan_jenis,
     pelanggan.`telepon` AS pelanggan_telepon,
     pelanggan.`alamat` AS pelanggan_alamat,
     nota.`idnota` AS nota_idnota,
     nota.`tgl` AS nota_tgl,
     nota.`id` AS nota_id,
     nota.`id_kasir` AS nota_id_kasir,
     kasir.`id_kasir` AS kasir_id_kasir,
     kasir.`nm_kasir` AS kasir_nm_kasir,
     kasir.`jkel` AS kasir_jkel,
     kasir.`no_telp` AS kasir_no_telp,
     kasir.`agama` AS kasir_agama,
     kasir.`alamat` AS kasir_alamat,
     kasir.`password` AS kasir_password,
     isi.`idnota` AS isi_idnota,
     isi.`kd_brg` AS isi_kd_brg,
     isi.`h_beli` AS isi_h_beli,
     isi.`h_jual` AS isi_h_jual,
     isi.`qty` AS isi_qty,
     barang.`kd_brg` AS barang_kd_brg,
     barang.`nm_brg` AS barang_nm_brg,
     barang.`jenis` AS barang_jenis,
     barang.`h_beli` AS barang_h_beli,
     barang.`h_jual` AS barang_h_jual
FROM
     `pelanggan` pelanggan INNER JOIN `nota` nota ON pelanggan.`id` = nota.`id`
     INNER JOIN `kasir` kasir ON nota.`id_kasir` = kasir.`id_kasir`
     INNER JOIN `isi` isi ON nota.`idnota` = isi.`idnota`
     INNER JOIN `barang` barang ON isi.`kd_brg` = barang.`kd_brg`
WHERE nota.idnota=$P{id_nota}]]>
	</queryString>
	<field name="pelanggan_id" class="java.lang.String"/>
	<field name="pelanggan_nmplg" class="java.lang.String"/>
	<field name="pelanggan_jenis" class="java.lang.String"/>
	<field name="pelanggan_telepon" class="java.lang.String"/>
	<field name="pelanggan_alamat" class="java.lang.String"/>
	<field name="nota_idnota" class="java.lang.String"/>
	<field name="nota_tgl" class="java.sql.Date"/>
	<field name="nota_id" class="java.lang.String"/>
	<field name="nota_id_kasir" class="java.lang.String"/>
	<field name="kasir_id_kasir" class="java.lang.String"/>
	<field name="kasir_nm_kasir" class="java.lang.String"/>
	<field name="kasir_jkel" class="java.lang.String"/>
	<field name="kasir_no_telp" class="java.lang.String"/>
	<field name="kasir_agama" class="java.lang.String"/>
	<field name="kasir_alamat" class="java.lang.String"/>
	<field name="kasir_password" class="java.lang.String"/>
	<field name="isi_idnota" class="java.lang.String"/>
	<field name="isi_kd_brg" class="java.lang.String"/>
	<field name="isi_h_beli" class="java.lang.Integer"/>
	<field name="isi_h_jual" class="java.lang.Integer"/>
	<field name="isi_qty" class="java.lang.Integer"/>
	<field name="barang_kd_brg" class="java.lang.String"/>
	<field name="barang_nm_brg" class="java.lang.String"/>
	<field name="barang_jenis" class="java.lang.String"/>
	<field name="barang_h_beli" class="java.lang.Integer"/>
	<field name="barang_h_jual" class="java.lang.Integer"/>
	<variable name="total" class="java.lang.Integer">
		<variableExpression><![CDATA[$F{isi_qty}*$F{isi_h_jual}]]></variableExpression>
	</variable>
	<variable name="totbe" class="java.lang.Integer" calculation="Sum">
		<variableExpression><![CDATA[$V{total}]]></variableExpression>
	</variable>
